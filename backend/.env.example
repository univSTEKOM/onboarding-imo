# ─────────────────────────────────────────────────────────────────────────────
# Backend environment — validated by src/config/env.ts (Zod). The app THROWS on
# startup if a required var is missing or invalid. Copy to `.env` and fill in.
# Required vars are uncommented; optional ones are commented with their default.
# ─────────────────────────────────────────────────────────────────────────────

# App / Server
# NODE_ENV=development            # development | production | test
# PORT=3000
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=*                 # comma-separated origins, or * for all
# LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal

# Database (PostgreSQL) — all required
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=root
DB_NAME=nest
# DB_SYNCHRONIZE=false            # on: auto-sync schema (dev). off: run migrations on boot (prod). defaults to true off-production
# DB_SEED=true                    # run the seeder on startup

# JWT — required, min 16 chars
JWT_SECRET=change_me_min_16_chars

# Admin seed account — required (created by the seeder)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123        # min 8 chars

# Depot media service — all required (storage is delegated to Depot)
# DEPOT_BASE_URL=https://media.example.com   # Depot service origin, no /api/v1
# DEPOT_API_KEY=mk_your_write_scoped_key      # per-app WRITE-scoped key

# Redis cache (optional — omit REDIS_HOST to use in-memory cache)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_TTL=3600                  # seconds
# REDIS_USERNAME=                 # Redis ACL user
# REDIS_PASSWORD=                 # Redis requirepass / ACL password

# OAuth / CAPTCHA (optional)
# GOOGLE_CLIENT_ID=               # enables Google login
# TURNSTILE_SECRET=               # enables the Cloudflare Turnstile CAPTCHA

# SSO / OIDC (optional — omit SSO_ISSUER to disable SSO login)
# SSO_ISSUER=https://passport.stekom.ac.id/oidc
# SSO_CLIENT_ID=your_sso_client_id
# SSO_CLIENT_SECRET=your_sso_client_secret
# SSO_REDIRECT_URI=http://localhost:3001/api/auth/sso/callback
# SSO_POST_LOGOUT_URI=http://localhost:3001
# SSO_SUCCESS_REDIRECT=/
# SSO_DEFAULT_ROLE=user

# Mailgun (optional — required for password-reset / verification emails)
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_FROM=no-reply@yourdomain.com
# MAILGUN_URL=https://api.eu.mailgun.net   # uncomment for EU region

# Rate limiting (optional — defaults: 100 req / 60 000 ms per IP)
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100
