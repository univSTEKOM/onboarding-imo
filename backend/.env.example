# App Configuration
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=*

# Logging (optional — default: info)
# LOG_LEVEL=info

# Rate Limiting (optional — defaults: 100 req / 60 000 ms per IP)
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=root
DB_NAME=nest

# S3 Configuration
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=sandbox
S3_ENDPOINT=https://sin1.contabostorage.com
S3_REGION=SIN

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600
# REDIS_USERNAME=
# REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=supersecret

# Mailgun Configuration (required for password reset emails)
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=no-reply@yourdomain.com
# MAILGUN_URL=https://api.eu.mailgun.net  # Uncomment for EU region

# SSO / OIDC Configuration (optional — omit SSO_ISSUER to disable SSO login)
# SSO_ISSUER=https://passport.stekom.ac.id/oidc
# SSO_CLIENT_ID=your_sso_client_id
# SSO_CLIENT_SECRET=your_sso_client_secret
# SSO_REDIRECT_URI=http://localhost:3001/api/auth/sso/callback
# SSO_POST_LOGOUT_URI=http://localhost:3001
# SSO_SUCCESS_REDIRECT=/
# SSO_DEFAULT_ROLE=user
